{
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://aikostnad.se/:path*",
      "permanent": true,
      "has": [{ "type": "host", "value": "aikostnad.com" }]
    },
    {
      "source": "/:path*",
      "destination": "https://aikostnad.se/:path*",
      "permanent": true,
      "has": [{ "type": "host", "value": "www.aikostnad.com" }]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400, stale-while-revalidate=3600" }
      ]
    }
  ]
}
